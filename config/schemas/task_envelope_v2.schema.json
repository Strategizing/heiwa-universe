{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "task_envelope_v2",
  "title": "Heiwa Task Envelope V2",
  "type": "object",
  "required": [
    "task_id",
    "parent_task_id",
    "plan_id",
    "step_id",
    "raw_text",
    "intent_class",
    "risk_level",
    "requires_approval",
    "requested_by",
    "source_channel_id",
    "source_message_id",
    "response_channel_id",
    "response_thread_id",
    "target_runtime",
    "target_tool",
    "steps"
  ],
  "properties": {
    "request_id": { "type": "string", "minLength": 1 },
    "timestamp": { "type": "string", "minLength": 1 },
    "source_surface": {
      "type": "string",
      "enum": ["cli", "discord", "api", "web", "voice", "slack", "desktop", "mcp"]
    },
    "sender_identity": { "type": "string" },
    "auth_token": { "type": "string" },
    "task_id": { "type": "string", "minLength": 1 },
    "parent_task_id": { "type": "string" },
    "plan_id": { "type": "string", "minLength": 1 },
    "step_id": { "type": "string", "minLength": 1 },
    "raw_text": { "type": "string", "minLength": 1 },
    "intent_class": {
      "type": "string",
      "enum": [
        "audit",
        "build",
        "research",
        "deploy",
        "operate",
        "strategy",
        "media",
        "automate",
        "automation",
        "mesh_ops",
        "self_buff",
        "status_check",
        "files",
        "chat",
        "general",
        "ping"
      ]
    },
    "urgency": { "type": "integer", "minimum": 1, "maximum": 5 },
    "privacy_level": {
      "type": "string",
      "enum": ["public", "internal", "sovereign"]
    },
    "budget_cap": {
      "type": "object",
      "properties": {
        "max_tokens": { "type": "integer", "minimum": 0 },
        "max_cost_usd": { "type": "number", "minimum": 0 }
      },
      "additionalProperties": true
    },
    "compute_pref": {
      "type": "string",
      "enum": ["local_first", "remote_ok", "any"]
    },
    "attachments": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": { "type": "string" },
          "uri": { "type": "string" },
          "size_bytes": { "type": "integer", "minimum": 0 }
        },
        "additionalProperties": true
      }
    },
    "response_target": {
      "type": "object",
      "properties": {
        "channel_id": { "oneOf": [{ "type": "integer" }, { "type": "string" }] },
        "thread_id": { "oneOf": [{ "type": "integer" }, { "type": "string" }, { "type": "null" }] },
        "surface": { "type": "string" }
      },
      "additionalProperties": true
    },
    "tenant_context": {
      "type": "object",
      "properties": {
        "org_id": { "type": "string" },
        "project_id": { "type": "string" },
        "scope": { "type": "string" }
      },
      "additionalProperties": true
    },
    "risk_level": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
    "requires_approval": { "type": "boolean" },
    "requested_by": { "type": "string", "minLength": 1 },
    "source_channel_id": { "oneOf": [{ "type": "integer" }, { "type": "string" }] },
    "source_message_id": { "oneOf": [{ "type": "integer" }, { "type": "string" }] },
    "response_channel_id": { "oneOf": [{ "type": "integer" }, { "type": "string" }] },
    "response_thread_id": { "oneOf": [{ "type": "integer" }, { "type": "string" }, { "type": "null" }] },
    "target_runtime": {
      "type": "string",
      "enum": ["railway", "macbook", "pc", "cloud", "both", "any"]
    },
    "target_tool": {
      "type": "string",
      "enum": [
        "codex",
        "gemini_cli",
        "antigravity",
        "openclaw",
        "picoclaw",
        "n8n",
        "ollama",
        "heiwa_ops",
        "heiwa_code",
        "heiwa_claw",
        "heiwa_reflex",
        "e2b"
      ]
    },
    "target_tier": { "type": "string" },
    "compute_class": { "type": "integer", "enum": [1, 2, 3, 4] },
    "normalization": { "type": "object" },
    "cost_usd": { "type": "number", "minimum": 0 },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["step_id", "title", "instruction", "subject", "target_runtime", "target_tool", "target_tier"],
        "properties": {
          "step_id": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "instruction": { "type": "string", "minLength": 1 },
          "subject": { "type": "string", "minLength": 1 },
          "target_runtime": {
            "type": "string",
            "enum": ["railway", "macbook", "pc", "cloud", "both", "any"]
          },
          "target_tool": {
            "type": "string",
            "enum": [
              "codex",
              "gemini_cli",
              "antigravity",
              "openclaw",
              "picoclaw",
              "n8n",
              "ollama",
              "heiwa_ops",
              "heiwa_code",
              "heiwa_claw",
              "heiwa_reflex",
              "e2b"
            ]
          },
          "target_tier": { "type": "string" },
          "required_capability": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
