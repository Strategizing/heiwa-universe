{
  "version": 13,
  "default_identity": "operator-general",
  "identities": [
    {
      "id": "operator-general",
      "description": "Default Heiwa operator identity. Local-first orchestration with cheap acceptable routing before premium escalation.",
      "trigger_keywords": [
        "heiwa",
        "ops",
        "fix",
        "status",
        "route",
        "task"
      ],
      "targets": {
        "tool": "openclaw",
        "runtime": "macbook@heiwa-node-a",
        "required_capabilities": [
          "orchestration_reasoning",
          "workspace_interaction"
        ]
      },
      "cells": [
        {
          "role": "scout",
          "model": "ollama/llama-4-scout:q4_k_m",
          "difficulty": "low"
        },
        {
          "role": "builder",
          "model": "ollama/glm-4.7-flash:q4_k_m",
          "difficulty": "medium"
        },
        {
          "role": "overflow",
          "model": "siliconflow/deepseek-r2",
          "difficulty": "high"
        }
      ],
      "models": {
        "openclaw": [
          "ollama/llama-4-scout:q4_k_m",
          "ollama/glm-4.7-flash:q4_k_m",
          "ollama/qwen3.5:4b",
          "siliconflow/deepseek-r2",
          "cerebras/gpt-oss-120b",
          "google-gemini-cli/gemini-3-pro-preview",
          "google-antigravity/gemini-3-pro-high",
          "claude-code/claude-opus-4-6",
          "openai-codex/gpt-5.3-codex"
        ]
      },
      "actions": {
        "discord_channel": "central-comms",
        "report_channel": "executive-briefing"
      }
    },
    {
      "id": "codex-builder",
      "description": "Premium build specialist for large implementation, repo mutation, and PR preparation.",
      "trigger_keywords": [
        "build",
        "implement",
        "code",
        "refactor",
        "patch",
        "pr"
      ],
      "targets": {
        "tool": "codex",
        "runtime": "cloud@class-3-build",
        "required_capabilities": [
          "agile_coding",
          "repo_mutation"
        ]
      },
      "cells": [
        {
          "role": "local_preflight",
          "model": "ollama/qwen3.5:4b",
          "difficulty": "medium"
        },
        {
          "role": "builder",
          "model": "openai-codex/gpt-5.3-codex",
          "difficulty": "high"
        },
        {
          "role": "reviewer",
          "model": "claude-code/claude-opus-4-6",
          "difficulty": "high"
        }
      ],
      "models": {
        "openclaw": [
          "ollama/qwen3.5:4b",
          "ollama/glm-4.7-flash:q4_k_m",
          "openai-codex/gpt-5.3-codex",
          "claude-code/claude-opus-4-6"
        ],
        "codex": [
          "openai-codex/gpt-5.3-codex"
        ]
      },
      "actions": {
        "discord_channel": "dev-labs",
        "report_channel": "executive-briefing"
      }
    },
    {
      "id": "research-scout",
      "description": "Gemini CLI aligned research and long-context synthesis specialist.",
      "trigger_keywords": [
        "research",
        "analyze",
        "investigate",
        "compare",
        "summarize",
        "long context"
      ],
      "targets": {
        "tool": "gemini_cli",
        "runtime": "cloud@class-3-research",
        "required_capabilities": [
          "research",
          "long_context",
          "web_access"
        ]
      },
      "cells": [
        {
          "role": "browser",
