          "difficulty": "low"
        },
        {
          "role": "synthesizer",
          "model": "google-gemini-cli/gemini-3-pro-preview",
          "difficulty": "high"
        }
      ],
      "models": {
        "openclaw": [
          "ollama/llama-4-scout:q4_k_m",
          "siliconflow/deepseek-r2",
          "cerebras/gpt-oss-120b",
          "google-gemini-cli/gemini-3-pro-preview"
        ],
        "gemini_cli": [
          "google-gemini-cli/gemini-3-pro-preview",
          "google-gemini-cli/gemini-3-flash-preview",
          "siliconflow/deepseek-r2",
          "cerebras/gpt-oss-120b"
        ]
      },
      "actions": {
        "discord_channel": "technical-research",
        "report_channel": "executive-briefing"
      }
    },
    {
