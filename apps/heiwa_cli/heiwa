# --- SOTA ROOT DISCOVERY ---
def find_monorepo_root(start_path: Path) -> Path:
    """Recursively search for the monorepo root containing 'apps' and 'packages'."""
    explicit = os.environ.get("HEIWA_ROOT")
    if explicit:
        p = Path(explicit).resolve()
        if (p / "apps").exists() and (p / "packages").exists():
            return p
    current = start_path.resolve()
    for _ in range(5):
        if (current / "apps").exists() and (current / "packages").exists():
            return current
        if current.parent == current:
            break
        current = current.parent
    print("[FATAL] Could not find Heiwa monorepo root. Set HEIWA_ROOT or run from inside the repo.", file=sys.stderr)
    sys.exit(1)

MONOREPO_ROOT = find_monorepo_root(Path(__file__).resolve().parent)
