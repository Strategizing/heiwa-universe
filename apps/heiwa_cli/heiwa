def cmd_login(args):
    """Authenticate and provision the local node identity."""
    print_banner()
    init_global_dir()
    login_target = args.name if args.name else "devon"
    is_devon = login_target.lower() == "devon"
    role = "admin" if is_devon else "heiwa-node"
    capabilities = ["compute", "orchestration", "browser", "ultimate_access"] if is_devon else ["compute", "orchestration"]
    
    identity = {
        "uuid": str(uuid.uuid4()),
        "name": login_target,
        "role": role,
        "capabilities": capabilities
    }
    with open(IDENTITY_FILE, "w") as f:
        json.dump(identity, f, indent=4)
    
    console.print(f"[success]🚀 Identity initialized:[/success] {login_target} ({role})")

def cmd_status(args):
    """Check hub connectivity, ingress readiness, and recent operator state."""
    print_banner()
    init_global_dir()

    table = Table(box=box.SIMPLE, show_header=False, border_style="dim")

    identity = _load_identity()
    configured_hub_url = settings.HUB_BASE_URL or "https://api.heiwa.ltd"
    auth_token = os.getenv("HEIWA_AUTH_TOKEN") or getattr(settings, "HEIWA_AUTH_TOKEN", "") or ""

    table.add_row(
        "[brand]Identity[/brand]",
        f"{identity.get('name', 'uninitialized')} ([dim]{identity.get('role', 'unknown')}[/dim])",
    )
    table.add_row("[brand]Node[/brand]", _node_name())
    table.add_row("[brand]Hub URL[/brand]", _redact_url_credentials(configured_hub_url))
    table.add_row("[brand]Auth[/brand]", "[success]set[/success]" if auth_token else "[warning]missing[/warning]")

    try:
        import psutil
        cpu = psutil.cpu_percent()
        ram = psutil.virtual_memory().percent
        table.add_row("[brand]CPU[/brand]", f"{cpu}%")
        table.add_row("[brand]RAM[/brand]", f"{ram}%")
    except ImportError:
        pass

    active_hub_url, health, health_error = _probe_hub_candidates()
    public_status = None
    public_error = None
    if health:
        public_status, public_error = _fetch_json(f"{active_hub_url}/status", timeout=5.0)
        if active_hub_url != configured_hub_url:
            table.add_row("[brand]Active Hub[/brand]", _redact_url_credentials(active_hub_url))

    if health:
        table.add_row("[brand]Hub Health[/brand]", f"[success]{health.get('status', 'unknown')}[/success]")
        table.add_row("[brand]Service[/brand]", str(health.get("service", "unknown")))
        table.add_row("[brand]State Backend[/brand]", str(health.get("state_backend", "unknown")))
        table.add_row("[brand]Transport[/brand]", str(health.get("gateway_transport", "unknown")))
    else:
        table.add_row("[brand]Hub Health[/brand]", f"[error]unreachable[/error] [dim]{health_error or ''}[/dim]")

    if public_status:
        table.add_row("[brand]Platform[/brand]", str(public_status.get("status", "unknown")))
        table.add_row("[brand]Live Nodes[/brand]", str(public_status.get("live_nodes", 0)))
        table.add_row("[brand]Active Models[/brand]", str(public_status.get("active_models", 0)))

    console.print(Panel(table, title="[bold white]Systems Overlay[/bold white]", border_style="brand"))

    usage_summary = list((public_status or {}).get("usage_summary") or [])
    if usage_summary:
        usage_table = Table(title="Active Model Usage", box=box.ROUNDED, header_style="brand")
        usage_table.add_column("Model", style="cyan")
        usage_table.add_column("Requests", justify="right")
        usage_table.add_column("Tokens", justify="right")
        for row in usage_summary[:5]:
            usage_table.add_row(
                str(row.get("model_id", "unknown")),
                str(row.get("request_count", 0)),
                str(row.get("total_tokens", 0)),
            )
        console.print(usage_table)
    elif health:
        console.print("[dim]Hub reachable, but no recent usage is recorded yet.[/dim]")

    if health_error or public_error:
        console.print("[dim]Tip: run[/dim] [bold]heiwa handshake[/bold] [dim]for a full authenticated ingress check.[/dim]")

def cmd_dispatch(args):
    """One-shot task dispatch to the swarm."""
    if not args.prompt:
        # If no prompt, print help for dispatch or enter interactive mode
        print_banner()
        console.print("[warning]Missing prompt.[/warning] Usage: [bold]heiwa <prompt>[/bold] or [bold]heiwa dispatch <prompt>[/bold]")
        return

    init_global_dir()
    python_bin = sys.executable
    dispatch_script = APPS_ROOT / "heiwa_cli/scripts/dispatch_once.py"
    
    node_name = "macbook@heiwa-agile"
    if IDENTITY_FILE.exists():
        with open(IDENTITY_FILE, "r") as f:
            identity = json.load(f)
            node_name = identity.get("name", node_name)

    cmd_args = [str(python_bin), str(dispatch_script), node_name, args.prompt]
    try:
        subprocess.run(cmd_args, check=True)
    except KeyboardInterrupt:
        pass
    except subprocess.CalledProcessError as e:
        sys.exit(e.returncode)

