def cmd_bench(args):
    """Run the unified HeiwaBench release-gate suites."""
    summary = HeiwaBench(MONOREPO_ROOT).run(suite=args.suite)
    if args.json:
        print(json.dumps(summary, indent=2))
        if not summary.get("ok"):
            sys.exit(1)
        return
    print_banner()
    if not args.json:
        table = Table(title="HeiwaBench", box=box.ROUNDED, header_style="brand")
        table.add_column("Suite", style="cyan")
        table.add_column("Cases", justify="right")
        table.add_column("Passed", justify="right")
        table.add_column("Status")
        for result in summary.get("results", []):
            total = len(result.get("cases", []))
            passed = sum(1 for case in result.get("cases", []) if case.get("ok"))
            table.add_row(
                result.get("suite", "unknown"),
                str(total),
                str(passed),
                "[success]PASS[/success]" if result.get("ok") else "[error]FAIL[/error]",
            )
        console.print(table)
        if summary.get("failures"):
            for failure in summary["failures"]:
                console.print(
                    f"[error]{failure['suite']}/{failure['case']}[/error] "
                    f"{failure['field']} expected={failure['expected']!r} actual={failure['actual']!r}"
                )
    if not summary.get("ok"):
        sys.exit(1)

def cmd_cells(args):
    """List or match the current HeiwaCells catalog."""
    catalog = HeiwaCellCatalog(MONOREPO_ROOT)
    if args.match:
        payload = catalog.recommend(args.match)
        if args.json:
            print(json.dumps(payload, indent=2))
            return
        print_banner()
        cell = payload.get("cell") or {}
        console.print(
            Panel(
                f"[brand]{cell.get('display_name', 'Unknown')}[/brand]\n"
                f"{cell.get('description', '')}\n\n"
                f"tool={cell.get('gateway_tool', '')}\n"
                f"runtime={cell.get('target_runtime', '')}\n"
                f"reason={payload.get('selection_reason', '')}\n"
                f"keywords={', '.join(payload.get('matched_keywords', [])) or 'none'}",
                title="Recommended HeiwaCell",
                border_style="brand",
            )
        )
        return

    payload = catalog.to_public_dict()
    if args.json:
        print(json.dumps(payload, indent=2))
        return

    print_banner()
    table = Table(title="HeiwaCells Catalog", box=box.ROUNDED, header_style="brand")
    table.add_column("Cell", style="cyan")
    table.add_column("Tool")
    table.add_column("Runtime")
    table.add_column("Capabilities")
    for cell in payload.get("cells", []):
        table.add_row(
            cell.get("cell_id", ""),
            cell.get("gateway_tool", ""),
            cell.get("target_runtime", ""),
            ", ".join(cell.get("required_capabilities", [])) or "none",
        )
    console.print(table)

def cmd_deploy(args):
    """Deploy Infrastructure and Compute."""
    print_banner()
    console.print("[brand]🚀 Initiating Global Deployment Sequence...[/brand]")
    
    if args.edge or args.full:
        console.print("\n[bold white]🛡️ Deploying Edge Configuration (Cloudflare)[/bold white]")
        tf_dir = MONOREPO_ROOT / "infra/cloud/cloudflare"
        if (tf_dir / "main.tf").exists():
            subprocess.run(f"cd {shlex.quote(str(tf_dir))} && terraform apply -auto-approve", shell=True)
            
    if args.compute or args.full or not (args.edge or args.compute or args.full):
        console.print("\n[bold white]☁️ Deploying Compute to Cloud HQ (Railway)[/bold white]")
        subprocess.run(f"railway up --detach", shell=True)

